---
import { SITE, SOCIALS } from "@/consts";
import { getCollection, type CollectionEntry } from "astro:content";

const Projects: CollectionEntry<"projects">[] = (
  await getCollection("projects")
).slice(0, 3);
---

<footer class="bg-primary container mx-auto rounded-t-[80px] p-10 space-y-8">
  <div
    class="flex flex-col lg:flex-row justify-between items-start lg:items-center gap-6"
  >
    <h2 class="text-5xl lg:text-9xl uppercase">{SITE.TITLE}</h2>
    <p class="text-2xl lg:text-3xl max-w-[760px]">
      シンプルさこそ究極の洗練である——コードにおいても。
    </p>
  </div>
  <div class="flex flex-col sm:flex-row sm:flex-wrap justify-between gap-10">
    <div>
      <h3 class="mb-2 text-xl">連絡先</h3>
      <ul>
        <li><a href={`mailto:${SITE.EMAIL}`}>{SITE.EMAIL}</a></li>
      </ul>
    </div>
    <div>
      <h3 class="mb-2 text-xl">ナビゲーション</h3>
      <ul class="space-y-1 text-secondary">
        <li><a href="/about">自己紹介</a></li>
        <li><a href="/projects">制作物</a></li>
        <li><a href="/links">リンク</a></li>
      </ul>
    </div>
    <div>
      <h3 class="mb-2 text-xl">SNS</h3>
      <ul class="space-y-1 text-secondary">
        {
          SOCIALS.map((link) => (
            <li>
              <a href={link.HREF}>{link.NAME}</a>
            </li>
          ))
        }
      </ul>
    </div>
    <div>
      <h3 class="mb-2 text-xl">プロジェクト</h3>
      <ul class="space-y-1 text-secondary">
        {
          Projects.map((project) => (
            <li>
                <a href=`/projects/${project.id}`>{project.data.title}</a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
  <span class="block text-center text-sm opacity-70">
    © {SITE.TITLE}. Astroで制作
  </span>
</footer>
